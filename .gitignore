# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Dependencies / build output
node_modules/
dist/
build/
.cache/
.next/
out/
storybook-static/
*.tsbuildinfo

# Env & secrets
.env
.env.*
!.env.example

# Test / coverage
coverage/
playwright-report/
test-results/

# Claude / impeccable — machine-local only (shared config IS committed so it travels to clones & worktrees)
.claude/settings.local.json
.impeccable/config.local.json
.impeccable/critiques/

# Logs & temp
*.log
*.tmp
tmp/

# Impeccable runtime / session artifacts (regenerated locally)
.impeccable/sessions/
.impeccable/cache/
.impeccable/*.log
.impeccable/hook.cache.json

# scratch driver scripts (never commit)
/drive-*.mjs
/cap.mjs
/probe.mjs
/scratch-*.mjs
/scratch-*.mts

# Guard: stray nested repo-name dir from agents misreading OpsParcero/ path prefixes
/OpsParcero/
