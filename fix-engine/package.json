    "@hono/node-server": "^2.0.0"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
