    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.2.5",
    "typescript": "^6.0.0",
    "vitest": "^4.1.9",
    "serve": "^14.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
