{
  "name": "opsparcero",
  "version": "0.1.0",
  "private": true,
  "description": "Kaseya Resolution Center — troubleshooting-first automation module (front-end mock)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "serve out -l 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:engine": "pnpm --filter @krc/fix-engine run test && pnpm --filter @krc/fix-engine run typecheck",
    "lint:stories": "node scripts/check-story-coverage.mjs",
    "smoke:fix-client": "fix-engine/node_modules/.bin/tsx --tsconfig ./tsconfig.json scripts/fix-client-smoke.mts",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run lint:stories && pnpm run test:engine && pnpm run smoke:fix-client && pnpm run test && pnpm run build && pnpm run build-storybook"
  },
  "dependencies": {
